default_platform(:android)

platform :android do
  desc "Run a beta pipeline"
  lane :beta do
    sh("make build")
    sh("make test")
  end

  desc "Run a release pipeline"
  lane :release do
    UI.message("Release lane expects signing via local.properties or BIUCING_RELEASE_* environment variables before distribution.")
    sh("./gradlew lint test assembleRelease")
  end
end
