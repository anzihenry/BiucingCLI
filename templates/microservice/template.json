{
  "name": "microservice",
  "description": "Go microservice starter with Protobuf, Buf, Compose, and OpenTelemetry",
  "category": "backend",
  "stack": ["Go", "Gin", "Protobuf", "Buf", "Docker Compose", "OpenTelemetry"],
  "tags": ["grpc", "otel", "protobuf", "docker", "service"],
  "platforms": ["linux", "container"],
  "maturity": {
    "level": "validated",
    "summary": "Containerized microservice starter with gRPC, protobuf generation, and observability workflows."
  },
  "validation": {
    "status": "real-build-verified",
    "verification_tier": "real-build",
    "evidence": [
      "python unittest template rendering coverage",
      "real docker runtime image builds",
      "real docker development image builds"
    ]
  },
  "operating_assumptions": [
    "The starter assumes a contract-first backend workflow with Buf and local dependency orchestration.",
    "Generated projects are expected to validate protobuf, service runtime, and container packaging together."
  ],
  "workflow_labels": ["bootstrap", "dev", "verify", "build", "runtime"],
  "variables": [
    {
      "name": "project_name",
      "required": true
    },
    {
      "name": "module_name",
      "required": true,
      "prompt": "Go module name: "
    },
    {
      "name": "service_name",
      "required": false,
      "default_from": "project_name"
    },
    {
      "name": "proto_package",
      "required": true,
      "prompt": "Proto package: "
    },
    {
      "name": "http_port",
      "required": false,
      "default": "8080"
    },
    {
      "name": "grpc_port",
      "required": false,
      "default": "9090"
    },
    {
      "name": "dependency_store",
      "required": false,
      "default": "postgres"
    },
    {
      "name": "otel_exporter_endpoint",
      "required": false,
      "default": "http://localhost:4318"
    }
  ],
  "next_steps": [
    "make bootstrap",
    "make dev",
    "make verify",
    "make up",
    "make docker-build"
  ]
}
