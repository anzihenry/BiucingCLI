{
  "name": "apple",
  "description": "Swift + Tuist Apple app starter for mid-sized teams",
  "stack": ["Swift", "Tuist", "SwiftPM", "fastlane"],
  "variables": [
    {
      "name": "project_name",
      "required": true
    },
    {
      "name": "display_name",
      "required": false,
      "default_from": "project_name"
    },
    {
      "name": "apple_platform",
      "required": false,
      "default": "ios"
    },
    {
      "name": "apple_platform_name",
      "required": false,
      "default": "iOS"
    },
    {
      "name": "bundle_identifier",
      "required": true,
      "prompt": "Bundle identifier: "
    },
    {
      "name": "organization_name",
      "required": false,
      "default": "Example Team"
    },
    {
      "name": "development_team",
      "required": false,
      "default": "DEVELOPMENT_TEAM_ID"
    },
    {
      "name": "minimum_os_version",
      "required": false,
      "default": "26.0"
    },
    {
      "name": "swift_module_name",
      "required": false
    }
  ],
  "next_steps": [
    "make bootstrap",
    "make doctor",
    "make generate",
    "make lint",
    "make test",
    "open {{PROJECT_NAME}}.xcworkspace"
  ]
}
