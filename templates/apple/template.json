{
  "name": "apple",
  "description": "Swift + Tuist Apple app starter for mid-sized teams",
  "category": "native",
  "stack": ["Swift", "Tuist", "SwiftPM", "fastlane"],
  "tags": ["apple", "swiftui", "tuist", "fastlane"],
  "platforms": ["ios", "macos", "watchos", "tvos"],
  "maturity": {
    "level": "validated",
    "summary": "Multi-platform Apple starter with doctor, generate, lint, and test workflows."
  },
  "validation": {
    "status": "generated-project-verified",
    "verification_tier": "generated-project",
    "evidence": [
      "python unittest template rendering coverage",
      "real generated project make generate/build/test validation"
    ]
  },
  "operating_assumptions": [
    "The starter assumes a native Apple workstation with Xcode-oriented tooling and simulator-first validation.",
    "Generated projects should keep bootstrap, doctor, generate, lint, and test workflows explicit."
  ],
  "workflow_labels": ["bootstrap", "doctor", "generate", "lint", "test", "open"],
  "variables": [
    {
      "name": "project_name",
      "required": true
    },
    {
      "name": "display_name",
      "required": false,
      "default_from": "project_name"
    },
    {
      "name": "apple_platform",
      "required": false,
      "default": "ios"
    },
    {
      "name": "apple_platform_name",
      "required": false,
      "default": "iOS"
    },
    {
      "name": "bundle_identifier",
      "required": true,
      "prompt": "Bundle identifier: "
    },
    {
      "name": "organization_name",
      "required": false,
      "default": "Example Team"
    },
    {
      "name": "development_team",
      "required": false,
      "default": "DEVELOPMENT_TEAM_ID"
    },
    {
      "name": "minimum_os_version",
      "required": false,
      "default": "26.0"
    },
    {
      "name": "swift_module_name",
      "required": false
    }
  ],
  "next_steps": [
    "make bootstrap",
    "make doctor",
    "make generate",
    "make lint",
    "make test",
    "open {{PROJECT_NAME}}.xcworkspace"
  ]
}
