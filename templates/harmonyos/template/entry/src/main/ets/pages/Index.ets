@Entry
@Component
struct Index {
  @State private buildChannel: string = 'local';

  build() {
    Column({ space: 20 }) {
      Text('{{DISPLAY_NAME}}')
        .fontSize(30)
        .fontWeight(FontWeight.Bold)
        .fontColor($r('app.color.text_primary'))

      Text('Generated by BiucingCLI')
        .fontSize(16)
        .fontColor($r('app.color.text_secondary'))

      Column({ space: 8 }) {
        Text('Bundle: {{BUNDLE_NAME}}')
          .fontSize(14)
        Text('Module: {{HARMONY_MODULE_NAME}}')
          .fontSize(14)
        Text(`Channel: ${this.buildChannel}`)
          .fontSize(14)
      }
      .alignItems(HorizontalAlign.Start)
      .padding(16)
      .borderRadius(12)
      .backgroundColor($r('app.color.surface'))
      .width('100%')
    }
    .justifyContent(FlexAlign.Center)
    .alignItems(HorizontalAlign.Center)
    .height('100%')
    .width('100%')
    .padding(24)
    .backgroundColor($r('app.color.page_background'))
  }
}
